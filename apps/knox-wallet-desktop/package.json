{
  "name": "knox-wallet-desktop",
  "version": "1.2.0",
  "description": "KNOX desktop wallet (React rewrite)",
  "main": "main.js",
  "author": "KNOX",
  "license": "UNLICENSED",
  "scripts": {
    "ensure:icon": "node scripts/ensure-build-icon.mjs",
    "renderer:build": "node scripts/build-renderer.mjs",
    "start": "npm run renderer:build && electron .",
    "dev": "npm run renderer:build && electron .",
    "predist": "npm run ensure:icon",
    "dist": "npm run renderer:build && electron-builder --win msi",
    "build": "npm run dist"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tanstack/react-query": "^5.90.21",
    "electron-store": "^11.0.2",
    "framer-motion": "^12.23.24",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-window": "^2.1.2",
    "selfsigned": "^2.4.1",
    "tailwindcss": "^4.1.12",
    "uplot": "^1.6.32",
    "xterm": "^5.3.0",
    "zod": "^4.1.5",
    "zustand": "^5.0.7"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.23.1"
  },
  "build": {
    "appId": "io.knox.wallet",
    "productName": "KNOX WALLET",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**",
      "assets/**"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin"
      }
    ],
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "icon": "icon.ico",
      "target": [
        "msi"
      ]
    },
    "msi": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "KNOX WALLET",
      "upgradeCode": "F7A83C2E-1B4D-4E8F-9A2B-3C5D6E7F8901",
      "runAfterFinish": true
    }
  }
}